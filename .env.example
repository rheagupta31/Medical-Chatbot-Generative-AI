# Copy this file to .env and fill in real values. Never commit .env.

# Required: vector database
PINECONE_API_KEY=
PINECONE_INDEX_NAME=medicalbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# LLM provider: "openai" or "gemini". Only the matching key below is required.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
# Free-tier daily quotas are per model; the lite model has a higher cap.
GEMINI_MODEL=gemini-flash-lite-latest

# Optional tuning
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
TOP_K=3
MAX_HISTORY_TURNS=6
DATA_DIR=Data/
